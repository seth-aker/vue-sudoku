# Use a hoisted node_modules layout instead of pnpm's default symlinked .pnpm/ tree.
# This is the standard recommendation for Expo + pnpm projects: RN / Metro / Jest
# tooling assumes a flat node_modules and breaks on pnpm's symlinks (e.g. Jest's
# transformIgnorePatterns regex can't match paths inside .pnpm/...).
node-linker=hoisted
