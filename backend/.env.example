PORT={NUMBER}
DB_CONNECTION_STRING={STRING}
DB_NAME={STRING}

NODE_ENV={STRING}
ORIGIN={STRING}
LOG_DIR={STRING} # this is actually the full log file path.
ROOT_DIR={STRING}
WORKER_PATH={STRING}
SESSION_SECRET={STRING} # >= 32 chars
JWT_SECRET={STRING}     # >= 32 chars, independent from SESSION_SECRET
JWT_TTL=7d              # forms: "3600" (sec), "15m", "12h", "7d". Optional, defaults to 7d.
